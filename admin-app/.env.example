# PostgreSQL connection
DATABASE_URL="postgresql://USER@localhost:5432/ob_cn_dev?schema=public"

# NextAuth (admin backend login)
AUTH_SECRET="change-me"

# Email verification codes (登录/注册) — any plain SMTP provider works.
# Use a non-Google provider (Brevo / Mailgun / 阿里云邮件推送 / 腾讯云 SES /
# self-hosted SMTP) so mail delivery works in regions without Google access.
# Leave SMTP_HOST unset in local dev: codes are printed to the server log.
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# EMAIL_FROM="OpenBible <no-reply@yourdomain.com>"

# Sign in with Apple — requires a paid Apple Developer account.
# Setup in https://developer.apple.com/account/:
#   1. Certificates, IDs & Profiles → Identifiers → create an App ID with the
#      "Sign in with Apple" capability.
#   2. Create a Services ID (this is APPLE_CLIENT_ID), enable Sign in with
#      Apple on it, and register the Return URL:
#        https://你的域名/api/auth/apple/callback
#      Apple only accepts HTTPS domains — no http, no localhost. For local
#      testing use an HTTPS tunnel (cloudflared / ngrok) and register the
#      tunnel URL as the Return URL, with APP_URL set to the tunnel origin.
#   3. Keys → create a "Sign in with Apple" key, download the .p8 file
#      (APPLE_KEY_ID is its Key ID; APPLE_TEAM_ID is in the top-right of the
#      developer portal).
# APPLE_CLIENT_ID=com.yourdomain.openbible.web
# APPLE_TEAM_ID=XXXXXXXXXX
# APPLE_KEY_ID=YYYYYYYYYY
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...p8 内容...\n-----END PRIVATE KEY-----"
# APP_URL=https://yourdomain.com
