# PostgreSQL connection
DATABASE_URL="postgresql://USER@localhost:5432/ob_cn_dev?schema=public"

# NextAuth (admin backend login)
AUTH_SECRET="change-me"

# Email verification codes (登录/注册) — any plain SMTP provider works.
# Use a non-Google provider (Brevo / Mailgun / 阿里云邮件推送 / 腾讯云 SES /
# self-hosted SMTP) so mail delivery works in regions without Google access.
# Leave SMTP_HOST unset in local dev: codes are printed to the server log.
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# EMAIL_FROM="OpenBible <no-reply@yourdomain.com>"
