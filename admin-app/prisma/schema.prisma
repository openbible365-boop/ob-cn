// OpenBible admin backend — data model for user & community management.
// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Admin backend operators (separate from app end-users) ----------

enum OperatorRole {
  SUPER_ADMIN
  MODERATOR
}

model Operator {
  id           String       @id @default(cuid())
  username     String       @unique
  passwordHash String
  name         String
  role         OperatorRole @default(SUPER_ADMIN)
  createdAt    DateTime     @default(now())

  auditLogs AuditLog[]
}

// ---------- End-users of the OpenBible app ----------

enum UserStatus {
  ACTIVE
  MUTED
  BANNED
}

enum UserTier {
  BASIC_FREE
  MID
  HIGH
}

enum AuthProvider {
  EMAIL
  APPLE
  GOOGLE
}

model User {
  id             String     @id @default(cuid())
  uid            Int        @unique @default(autoincrement())
  name           String
  email          String?    @unique
  avatarColor    String     @default("#FFD465")
  avatarUrl      String?
  tier           UserTier   @default(BASIC_FREE)
  tierPriceCents Int        @default(0)
  status         UserStatus @default(ACTIVE)
  mutedUntil     DateTime?
  banReason      String?
  lastLoginAt    DateTime?
  createdAt      DateTime   @default(now())

  authAccounts          AuthAccount[]
  memberships           Membership[]
  ownedCommunities      Community[]            @relation("CommunityOwner")
  posts                 Post[]
  postLikes             PostLike[]
  eventSignups          EventSignup[]
  highlights            Highlight[]
  notes                 Note[]
  conversations         Conversation[]
  notificationSettings  NotificationSetting[]
  communityJoinRequests CommunityJoinRequest[] @relation("CommunityJoinRequester")
  reviewedJoinRequests  CommunityJoinRequest[] @relation("CommunityJoinReviewer")
}

model AuthAccount {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@unique([provider, providerAccountId])
}

// ---------- Communities (分社群) ----------

enum CommunityTier {
  OFFICIAL_FREE
  BASIC_FREE
  MID
  HIGH
}

enum CommunityStatus {
  ACTIVE
  BANNED
  DISSOLVED
}

enum CommunityJoinPolicy {
  OPEN
  APPROVAL
  INVITE_ONLY
}

model Community {
  id                String              @id @default(cuid())
  parentId          String?             @map("parent_id")
  name              String
  abbreviation      String              @unique
  description       String?
  avatarColor       String              @default("#FFD465")
  isOfficial        Boolean             @default(false)
  joinPolicy        CommunityJoinPolicy @default(APPROVAL)
  tier              CommunityTier       @default(BASIC_FREE)
  tierPriceCents    Int                 @default(0)
  ownerId           String?             @unique
  warningCount      Int                 @default(0)
  status            CommunityStatus     @default(ACTIVE)
  dailyActivity     Int                 @default(0)
  aiTokensToday     Int                 @default(0)
  aiTokenDailyLimit Int?
  createdAt         DateTime            @default(now())

  parent       Community?             @relation("CommunityGroups", fields: [parentId], references: [id], onDelete: Cascade)
  groups       Community[]            @relation("CommunityGroups")
  owner        User?                  @relation("CommunityOwner", fields: [ownerId], references: [id])
  memberships  Membership[]
  posts        Post[]
  reports      Report[]
  events       Event[]
  joinRequests CommunityJoinRequest[]

  @@index([parentId])
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

model Membership {
  id          String         @id @default(cuid())
  userId      String
  communityId String
  role        MembershipRole @default(MEMBER)
  joinedAt    DateTime       @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
}

enum CommunityJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model CommunityJoinRequest {
  id          String                     @id @default(cuid())
  userId      String
  communityId String
  status      CommunityJoinRequestStatus @default(PENDING)
  message     String?
  reviewerId  String?
  reviewedAt  DateTime?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  user      User      @relation("CommunityJoinRequester", fields: [userId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  reviewer  User?     @relation("CommunityJoinReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@unique([userId, communityId])
  @@index([communityId, status])
  @@index([userId, status])
}

// ---------- Dashboard: daily snapshots ----------
// Real end-user apps don't emit usage events yet (mobile/web clients are
// still static prototypes). Until a real event pipeline exists, an
// aggregation job (or this seed script) writes one row per day here, and
// the dashboard reads it like any other real table. Swapping the seed for
// a real nightly aggregation later requires no page changes.

model DailyMetric {
  id                  String   @id @default(cuid())
  date                DateTime @unique @db.Date
  dau                 Int
  mau                 Int
  retentionD1Pct      Float
  retentionD7Pct      Float
  retentionD30Pct     Float
  huiduPenetrationPct Float
  avgRoundsPerSession Float
  bibleReadingPct     Int
  huiduPct            Int
  communityPct        Int
  annotationPct       Int
  aiCallCount         Int
  aiTokenCount        Int
  aiAvgFirstTokenMs   Int
  aiLikeRatePct       Float
}

model HotTopic {
  id    String   @id @default(cuid())
  date  DateTime @db.Date
  label String
  rank  Int
}

// ---------- AI model & prompt management ----------

model AiSettings {
  id                  String  @id @default("singleton")
  autoFallbackEnabled Boolean @default(true)
  rateLimited         Boolean @default(false)
  monthLabel          String
  monthlyBudgetCents  Int
  monthSpendCents     Int
}

enum AiModelRole {
  PRIMARY
  BACKUP
}

enum AiModelStatus {
  NORMAL
  STANDBY
  DEGRADED
}

model AiModel {
  id              String        @id @default(cuid())
  role            AiModelRole   @unique
  provider        String
  modelName       String
  temperature     Float
  status          AiModelStatus @default(NORMAL)
  apiKeyLast4     String?
  apiKeyUpdatedAt DateTime?
}

enum PromptVersionStatus {
  CANARY
  GA
  ARCHIVED
}

model PromptVersion {
  id             String              @id @default(cuid())
  version        String              @unique
  description    String
  status         PromptVersionStatus @default(CANARY)
  rolloutPercent Int                 @default(10)
  likeRatePct    Float?
  dislikeRatePct Float?
  createdAt      DateTime            @default(now())
}

// ---------- Content management & moderation ----------

enum PostStatus {
  VISIBLE
  HIDDEN
  DELETED
}

model Post {
  id           String     @id @default(cuid())
  communityId  String
  authorId     String
  content      String
  verseRef     String?
  likeCount    Int        @default(0)
  commentCount Int        @default(0)
  status       PostStatus @default(VISIBLE)
  createdAt    DateTime   @default(now())

  community Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [authorId], references: [id])
  reports   Report[]
  likes     PostLike[]
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

enum SensitiveWordLevel {
  BLOCK
  REVIEW
  LOG
}

model SensitiveWord {
  id        String             @id @default(cuid())
  word      String             @unique
  level     SensitiveWordLevel
  createdAt DateTime           @default(now())
}

enum ReportHitLevel {
  BLOCK
  REVIEW
  LOG
}

enum ReportStatus {
  PENDING
  RESOLVED
}

model Report {
  id              String         @id @default(cuid())
  postId          String?
  communityId     String
  contentSnapshot String
  reason          String
  hitLevel        ReportHitLevel
  status          ReportStatus   @default(PENDING)
  resolution      String?
  createdAt       DateTime       @default(now())
  resolvedAt      DateTime?

  post      Post?     @relation(fields: [postId], references: [id])
  community Community @relation(fields: [communityId], references: [id])
}

// ---------- Event supervision (活动监管) ----------

model Event {
  id          String    @id @default(cuid())
  communityId String
  title       String
  startAt     DateTime
  endAt       DateTime?
  signupCount Int       @default(0)
  createdAt   DateTime  @default(now())

  community Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  signups   EventSignup[]
}

model EventSignup {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

// ---------- Permissions & audit ----------

model AuditLog {
  id         String   @id @default(cuid())
  operatorId String
  action     String
  targetType String
  targetId   String
  detail     String
  createdAt  DateTime @default(now())

  operator Operator @relation(fields: [operatorId], references: [id])
}

// ---------- Bible reading, commentary, highlights & notes ----------

model Verse {
  id          String @id @default(cuid())
  translation String
  book        String
  bookOrder   Int
  chapter     Int
  verse       Int
  text        String

  @@unique([translation, book, chapter, verse])
  @@index([translation, book, chapter])
  @@index([translation, bookOrder, chapter])
}

model Commentary {
  id         String  @id @default(cuid())
  book       String
  chapter    Int
  rangeStart Int
  rangeEnd   Int
  title      String
  body       String
  highlight  Boolean @default(false)

  @@index([book, chapter])
}

model Highlight {
  id        String   @id @default(cuid())
  userId    String
  book      String
  chapter   Int
  verse     Int
  color     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, book, chapter, verse])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  book      String
  chapter   Int
  verse     Int
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------- 慧读 (AI reading assistant) conversations ----------

model Conversation {
  id            String   @id @default(cuid())
  userId        String
  translation   String
  book          String
  chapter       Int
  verseStart    Int
  verseEnd      Int
  verseRefLabel String
  verseText     String
  title         String
  createdAt     DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
}

enum MessageRole {
  USER
  ASSISTANT
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  blocks         Json?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ---------- Per-user notification preferences (网站「通知管理」) ----------

model NotificationSetting {
  id      String  @id @default(cuid())
  userId  String
  key     String
  enabled Boolean

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

// ---------- Email verification codes (登录/注册) ----------
// Codes are stored hashed; a code is valid for 10 minutes, allows 5 attempts,
// and is consumed on successful login.

model VerificationCode {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, createdAt])
}
