<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">@color/startup_background</item>
        <item name="android:colorAccent">@color/startup_gold</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/startup_background</item>
        <item name="android:navigationBarColor">@color/startup_background</item>
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowBackground">@drawable/openbible_launch_screen</item>
        <item name="android:background">@drawable/openbible_launch_screen</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/startup_background</item>
        <item name="android:navigationBarColor">@color/startup_background</item>
    </style>
</resources>
